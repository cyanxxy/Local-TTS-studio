+        device_type
     });
+    bind_thread_stream(device_type);
+}
+
+fn bind_thread_stream(device_type: ffi::mlx_device_type) -> ffi::mlx_stream {
+    THREAD_STREAM.with(|cell| {
+        let mut stream = cell.borrow_mut();
+        if stream.is_none() {
+            let ptr = match device_type {
+                ffi::mlx_device_type::MLX_GPU => unsafe { ffi::mlx_default_gpu_stream_new() },
+                ffi::mlx_device_type::MLX_CPU => unsafe { ffi::mlx_default_cpu_stream_new() },
+            };
+            *stream = Some(MlxStream { ptr });
+        }
+        let ptr = stream.as_ref().expect("thread stream just initialized").ptr;
+        unsafe { ffi::mlx_set_default_stream(ptr) };
+        ptr
+    })
 }
 
