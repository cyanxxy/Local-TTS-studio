+    /// Build the dual-stream prompt used by VoiceDesign models.
+    ///
+    /// VoiceDesign is conditioned by instruction text and intentionally omits
+    /// the predefined-speaker codec token used by CustomVoice.
+    #[allow(clippy::too_many_arguments)]
+    pub fn build_voice_design_input_embeddings(
+        &self,
+        text_token_ids: &[i64],
+        language_id: Option<i64>,
+        tts_pad_id: i64,
+        tts_bos_id: i64,
+        tts_eos_id: i64,
+        codec_think_id: i64,
+        codec_nothink_id: i64,
+        codec_think_bos_id: i64,
+        codec_think_eos_id: i64,
+        codec_pad_id: i64,
+        codec_bos_id: i64,
+    ) -> Tensor {
+        let role_embed = self.embed_text(&text_token_ids[..3]);
+        let special_text = self.embed_text(&[tts_pad_id, tts_bos_id, tts_eos_id]);
+        let tts_pad_embed = special_text.narrow(1, 0, 1);
+        let tts_bos_embed = special_text.narrow(1, 1, 1);
+        let tts_eos_embed = special_text.narrow(1, 2, 1);
+
+        let mut codec_prefill = match language_id {
+            Some(language_id) => vec![
+                codec_think_id,
+                codec_think_bos_id,
+                language_id,
+                codec_think_eos_id,
+            ],
+            None => vec![codec_nothink_id, codec_think_bos_id, codec_think_eos_id],
+        };
+        codec_prefill.extend_from_slice(&[codec_pad_id, codec_bos_id]);
+        let codec_prefix = self.embed_codec(&codec_prefill);
+        let prefix_without_bos_len = codec_prefix.size()[1] - 1;
+        let pad_count = prefix_without_bos_len - 1;
+        let text_for_codec = Tensor::cat(
+            &[
+                tts_pad_embed.expand(&[1, pad_count, self.hidden_size], false),
+                tts_bos_embed.shallow_clone(),
+            ],
+            1,
+        );
+        let phase2 = &text_for_codec + &codec_prefix.narrow(1, 0, prefix_without_bos_len);
+
+        let text_end = text_token_ids.len().saturating_sub(5);
+        let text_content_ids = &text_token_ids[3..text_end];
+        let text_content_embed = if text_content_ids.is_empty() {
+            Tensor::zeros(&[1, 0, self.hidden_size], DType::Float32, self.device)
+        } else {
+            self.embed_text(text_content_ids)
+        };
+        let text_with_eos = Tensor::cat(&[text_content_embed, tts_eos_embed], 1);
+        let codec_pad_repeated = self
+            .embed_codec(&[codec_pad_id])
+            .expand(&[1, text_with_eos.size()[1], self.hidden_size], false);
+        let phase3 = &text_with_eos + &codec_pad_repeated;
+        let phase4 = &tts_pad_embed + &codec_prefix.narrow(1, prefix_without_bos_len, 1);
+
+        Tensor::cat(&[role_embed, phase2, phase3, phase4], 1)
+    }
