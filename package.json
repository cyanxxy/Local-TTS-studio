{
  "name": "offline-voice-studio",
  "private": true,
  "version": "1.7.1",
  "description": "A local-first text-to-speech studio for the web and desktop.",
  "author": "cyanxxy",
  "license": "Apache-2.0",
  "homepage": "https://github.com/cyanxxy/Local-TTS-studio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanxxy/Local-TTS-studio.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --port 5173",
    "build:rust": "node scripts/build-rust-bridge.mjs",
    "build:electron:main": "npm run build:rust && node -e \"require('node:fs').rmSync('dist-electron', { recursive: true, force: true })\" && tsc -p tsconfig.electron.json && esbuild electron/preload.ts --bundle --platform=node --format=cjs --target=node22 --external:electron --outfile=dist-electron/preload.js && node -e \"require('node:fs').copyFileSync('electron/package.json', 'dist-electron/package.json')\"",
    "dev:desktop": "npm run build:electron:main && concurrently \"npm run dev:web\" \"wait-on http://localhost:5173/desktop/studio && electron .\"",
    "dev:electron": "npm run dev:desktop",
    "build": "npm run build:web",
    "build:web": "tsc -b && vite build",
    "build:desktop": "npm run build:web && npm run build:electron:main",
    "build:electron": "npm run build:desktop",
    "dist": "npm run build:electron && electron-builder",
    "dist:mac": "npm run build:electron && electron-builder --mac --arm64",
    "dist:win": "npm run build:electron && electron-builder --win --x64",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "npm run test:js && npm run test:rust",
    "test:js": "vitest run",
    "test:rust": "node scripts/test-rust-bridge.mjs",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "eval:inference": "node scripts/inference-speed-eval.mjs"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.3.0",
    "@fontsource-variable/literata": "^5.3.0",
    "@fontsource-variable/outfit": "^5.3.0",
    "@huggingface/transformers": "4.2.0",
    "@llamaindex/liteparse": "^2.8.0",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/vite": "^4.3.3",
    "fflate": "^0.8.3",
    "kokoro-js": "1.2.1",
    "lucide-react": "^1.26.0",
    "onnxruntime-web": "1.27.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "concurrently": "^9.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.2.2",
    "vitest": "^3.2.4",
    "wait-on": "^9.1.0"
  },
  "build": {
    "appId": "com.opentts.desktop",
    "productName": "Open TTS",
    "mac": {
      "artifactName": "Open-TTS-${version}-macOS-${arch}-unsigned.${ext}",
      "category": "public.app-category.productivity",
      "minimumSystemVersion": "26.0",
      "identity": null,
      "hardenedRuntime": false,
      "notarize": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "artifactName": "Open-TTS-${version}-Windows-${arch}-CPU.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    },
    "electronFuses": {
      "runAsNode": false,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "grantFileProtocolExtraPrivileges": false
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist-electron/**/*.test.js"
    ],
    "asarUnpack": [
      "**/node_modules/@llamaindex/**"
    ],
    "extraResources": [
      {
        "from": "dist-rust",
        "to": "dist-rust",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
